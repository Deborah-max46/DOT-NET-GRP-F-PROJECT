@{
    ViewData["Title"] = "Consumer Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Consumer Dashboard – Consumer's Voice</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f1f5f9;
        }

        /* SIDEBAR */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 260px;
            height: 100vh;
            background: linear-gradient(180deg, #1a1a2e, #16213e);
            color: white;
            padding: 0;
            display: flex;
            flex-direction: column;
            z-index: 100;
        }

        .sidebar-header {
            padding: 28px 24px;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

        .sidebar-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 16px;
            font-weight: 700;
        }

        .sidebar-logo-icon {
            width: 36px;
            height: 36px;
            background: #2563eb;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
        }

        .sidebar-role {
            margin-top: 8px;
            font-size: 11px;
            color: #10b981;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .sidebar-nav {
            flex: 1;
            padding: 20px 0;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 13px 24px;
            font-size: 14px;
            color: #94a3b8;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            border-left: 3px solid transparent;
        }

            .nav-item:hover {
                color: white;
                background: rgba(255,255,255,0.05);
            }

            .nav-item.active {
                color: white;
                background: rgba(37,99,235,0.15);
                border-left-color: #2563eb;
            }

            .nav-item i {
                width: 18px;
                text-align: center;
            }

        .sidebar-footer {
            padding: 20px 24px;
            border-top: 1px solid rgba(255,255,255,0.08);
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            color: #f87171;
            font-size: 14px;
            text-decoration: none;
            transition: color 0.2s;
        }

            .logout-btn:hover {
                color: #ef4444;
            }

        /* MAIN */
        .main {
            margin-left: 260px;
            padding: 32px;
        }

        /* TOPBAR */
        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
        }

            .topbar h1 {
                font-size: 24px;
                font-weight: 800;
                color: #1a1a2e;
            }

            .topbar p {
                font-size: 14px;
                color: #64748b;
                margin-top: 2px;
            }

        .user-badge {
            display: flex;
            align-items: center;
            gap: 12px;
            background: white;
            padding: 10px 18px;
            border-radius: 50px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }

        .user-avatar {
            width: 36px;
            height: 36px;
            background: #2563eb;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 14px;
        }

        .user-info .name {
            font-size: 13px;
            font-weight: 700;
            color: #1a1a2e;
        }

        .user-info .role {
            font-size: 11px;
            color: #10b981;
            font-weight: 600;
        }

        /* STAT CARDS */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 28px;
        }

        .stat-card {
            background: white;
            border-radius: 14px;
            padding: 24px;
            display: flex;
            align-items: center;
            gap: 16px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

        .stat-icon {
            width: 52px;
            height: 52px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
        }

            .stat-icon.blue {
                background: #eff6ff;
            }

            .stat-icon.green {
                background: #f0fdf4;
            }

            .stat-icon.amber {
                background: #fffbeb;
            }

            .stat-icon.red {
                background: #fef2f2;
            }

        .stat-number {
            font-size: 28px;
            font-weight: 800;
            color: #1a1a2e;
        }

        .stat-label {
            font-size: 12px;
            color: #64748b;
            margin-top: 2px;
        }

        /* CARDS */
        .card-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 20px;
        }

        .card {
            background: white;
            border-radius: 14px;
            padding: 28px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

            .card h3 {
                font-size: 16px;
                font-weight: 700;
                color: #1a1a2e;
                margin-bottom: 20px;
                display: flex;
                align-items: center;
                gap: 8px;
            }

        /* COMPLAINT LIST */
        .complaint-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 0;
            border-bottom: 1px solid #f1f5f9;
        }

            .complaint-item:last-child {
                border-bottom: none;
            }

        .complaint-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: #eff6ff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .complaint-title {
            font-size: 13px;
            font-weight: 600;
            color: #1a1a2e;
        }

        .complaint-date {
            font-size: 11px;
            color: #94a3b8;
            margin-top: 2px;
        }

        .badge-status {
            margin-left: auto;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            flex-shrink: 0;
        }

        .badge-pending {
            background: #fffbeb;
            color: #d97706;
        }

        .badge-progress {
            background: #eff6ff;
            color: #2563eb;
        }

        .badge-resolved {
            background: #f0fdf4;
            color: #16a34a;
        }

        /* QUICK ACTIONS */
        .action-btn {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 16px;
            border-radius: 10px;
            border: 2px solid #e2e8f0;
            margin-bottom: 10px;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            color: #1a1a2e;
            font-size: 13px;
            font-weight: 600;
        }

            .action-btn:hover {
                border-color: #2563eb;
                background: #eff6ff;
                color: #2563eb;
            }

            .action-btn i {
                color: #2563eb;
                width: 16px;
            }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-logo">
                <div class="sidebar-logo-icon"><i class="fas fa-shield-alt"></i></div>
                Consumer's Voice
            </div>
            <div class="sidebar-role">● Consumer Portal</div>
        </div>
        <nav class="sidebar-nav">
            <a class="nav-item active" href="#">
                <i class="fas fa-home"></i> Dashboard
            </a>
            <a class="nav-item" href="#">
                <i class="fas fa-plus-circle"></i> Submit Complaint
            </a>
            <a class="nav-item" href="#">
                <i class="fas fa-list"></i> My Complaints
            </a>
            <a class="nav-item" href="#">
                <i class="fas fa-bell"></i> Notifications
            </a>
            <a class="nav-item" href="#">
                <i class="fas fa-book"></i> Know Your Rights
            </a>
            <a class="nav-item" href="#">
                <i class="fas fa-user"></i> My Profile
            </a>
        </nav>
        <div class="sidebar-footer">
            <a href="/Home/Logout" class="logout-btn">
                <i class="fas fa-sign-out-alt"></i> Logout
            </a>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main">

        <!-- TOPBAR -->
        <div class="topbar">
            <div>
                <h1>Welcome back, @ViewBag.UserName 👋</h1>
                <p>Here is a summary of your consumer activity</p>
            </div>
            <div class="user-badge">
                <div class="user-avatar">@(ViewBag.UserName?.ToString().Substring(0, 1))</div>
                <div class="user-info">
                    <div class="name">@ViewBag.UserName</div>
                    <div class="role">Consumer</div>
                </div>
            </div>
        </div>

        <!-- STATS -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon blue">📋</div>
                <div>
                    <div class="stat-number">3</div>
                    <div class="stat-label">Total Complaints</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon amber">⏳</div>
                <div>
                    <div class="stat-number">1</div>
                    <div class="stat-label">Pending Review</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon blue">🔄</div>
                <div>
                    <div class="stat-number">1</div>
                    <div class="stat-label">In Progress</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green">✅</div>
                <div>
                    <div class="stat-number">1</div>
                    <div class="stat-label">Resolved</div>
                </div>
            </div>
        </div>

        <!-- CARDS -->
        <div class="card-grid">
            <div class="card">
                <h3>📋 My Recent Complaints</h3>
                <div class="complaint-item">
                    <div class="complaint-icon">🛒</div>
                    <div>
                        <div class="complaint-title">Defective Product – Kigali Market</div>
                        <div class="complaint-date">Submitted: March 10, 2026</div>
                    </div>
                    <span class="badge-status badge-resolved">Resolved</span>
                </div>
                <div class="complaint-item">
                    <div class="complaint-icon">💰</div>
                    <div>
                        <div class="complaint-title">Overcharging – MTN Mobile Money</div>
                        <div class="complaint-date">Submitted: March 15, 2026</div>
                    </div>
                    <span class="badge-status badge-progress">In Progress</span>
                </div>
                <div class="complaint-item">
                    <div class="complaint-icon">🍔</div>
                    <div>
                        <div class="complaint-title">Food Safety Issue – Restaurant</div>
                        <div class="complaint-date">Submitted: March 18, 2026</div>
                    </div>
                    <span class="badge-status badge-pending">Pending</span>
                </div>
            </div>

            <div class="card">
                <h3>⚡ Quick Actions</h3>
                <a href="#" class="action-btn">
                    <i class="fas fa-plus"></i> Submit New Complaint
                </a>
                <a href="#" class="action-btn">
                    <i class="fas fa-search"></i> Track My Case
                </a>
                <a href="#" class="action-btn">
                    <i class="fas fa-file-download"></i> Download Report
                </a>
                <a href="#" class="action-btn">
                    <i class="fas fa-headset"></i> Contact Support
                </a>
                <a href="#" class="action-btn">
                    <i class="fas fa-graduation-cap"></i> Learn My Rights
                </a>
            </div>
        </div>

    </div>
</body>
</html>
