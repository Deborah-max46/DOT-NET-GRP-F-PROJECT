@{
    ViewData["Title"] = "Business Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Business Dashboard – Consumer's Voice</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f1f5f9;
        }

        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 260px;
            height: 100vh;
            background: linear-gradient(180deg, #3b0764, #4c1d95);
            color: white;
            display: flex;
            flex-direction: column;
            z-index: 100;
        }

        .sidebar-header {
            padding: 28px 24px;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

        .sidebar-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 16px;
            font-weight: 700;
        }

        .sidebar-logo-icon {
            width: 36px;
            height: 36px;
            background: #9333ea;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
        }

        .sidebar-role {
            margin-top: 8px;
            font-size: 11px;
            color: #d8b4fe;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .sidebar-nav {
            flex: 1;
            padding: 20px 0;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 13px 24px;
            font-size: 14px;
            color: #e9d5ff;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            border-left: 3px solid transparent;
        }

            .nav-item:hover {
                color: white;
                background: rgba(255,255,255,0.05);
            }

            .nav-item.active {
                color: white;
                background: rgba(147,51,234,0.2);
                border-left-color: #9333ea;
            }

            .nav-item i {
                width: 18px;
                text-align: center;
            }

        .sidebar-footer {
            padding: 20px 24px;
            border-top: 1px solid rgba(255,255,255,0.08);
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            color: #f87171;
            font-size: 14px;
            text-decoration: none;
        }

            .logout-btn:hover {
                color: #ef4444;
            }

        .main {
            margin-left: 260px;
            padding: 32px;
        }

        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
        }

            .topbar h1 {
                font-size: 24px;
                font-weight: 800;
                color: #1a1a2e;
            }

            .topbar p {
                font-size: 14px;
                color: #64748b;
                margin-top: 2px;
            }

        .user-badge {
            display: flex;
            align-items: center;
            gap: 12px;
            background: white;
            padding: 10px 18px;
            border-radius: 50px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }

        .user-avatar {
            width: 36px;
            height: 36px;
            background: #9333ea;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 14px;
        }

        .user-info .name {
            font-size: 13px;
            font-weight: 700;
            color: #1a1a2e;
        }

        .user-info .role {
            font-size: 11px;
            color: #9333ea;
            font-weight: 600;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 28px;
        }

        .stat-card {
            background: white;
            border-radius: 14px;
            padding: 24px;
            display: flex;
            align-items: center;
            gap: 16px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

        .stat-icon {
            width: 52px;
            height: 52px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
        }

            .stat-icon.purple {
                background: #fdf4ff;
            }

            .stat-icon.red {
                background: #fef2f2;
            }

            .stat-icon.green {
                background: #f0fdf4;
            }

            .stat-icon.amber {
                background: #fffbeb;
            }

        .stat-number {
            font-size: 28px;
            font-weight: 800;
            color: #1a1a2e;
        }

        .stat-label {
            font-size: 12px;
            color: #64748b;
            margin-top: 2px;
        }

        .card-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 20px;
        }

        .card {
            background: white;
            border-radius: 14px;
            padding: 28px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            margin-bottom: 20px;
        }

            .card h3 {
                font-size: 16px;
                font-weight: 700;
                color: #1a1a2e;
                margin-bottom: 20px;
            }

        .complaint-item {
            padding: 16px;
            border: 1px solid #f1f5f9;
            border-radius: 10px;
            margin-bottom: 10px;
            transition: all 0.2s;
        }

            .complaint-item:hover {
                border-color: #9333ea;
                background: #fdf4ff;
            }

        .complaint-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 8px;
        }

        .complaint-title {
            font-size: 13px;
            font-weight: 700;
            color: #1a1a2e;
        }

        .complaint-meta {
            font-size: 11px;
            color: #94a3b8;
            margin-top: 3px;
        }

        .badge-status {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
        }

        .badge-new {
            background: #fef2f2;
            color: #dc2626;
        }

        .badge-progress {
            background: #eff6ff;
            color: #2563eb;
        }

        .badge-resolved {
            background: #f0fdf4;
            color: #16a34a;
        }

        .respond-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            margin-top: 10px;
            padding: 6px 14px;
            background: #9333ea;
            color: white;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.2s;
        }

            .respond-btn:hover {
                background: #7e22ce;
                color: white;
            }

        /* RATING */
        .rating-box {
            text-align: center;
            padding: 24px;
            border: 2px solid #e9d5ff;
            border-radius: 12px;
            margin-bottom: 16px;
        }

        .rating-score {
            font-size: 48px;
            font-weight: 800;
            color: #9333ea;
            line-height: 1;
        }

        .rating-label {
            font-size: 12px;
            color: #64748b;
            margin-top: 6px;
        }

        .stars {
            color: #f59e0b;
            font-size: 18px;
            margin: 8px 0;
        }

        .action-btn {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 16px;
            border-radius: 10px;
            border: 2px solid #e2e8f0;
            margin-bottom: 10px;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            color: #1a1a2e;
            font-size: 13px;
            font-weight: 600;
        }

            .action-btn:hover {
                border-color: #9333ea;
                background: #fdf4ff;
                color: #4c1d95;
            }

            .action-btn i {
                color: #9333ea;
                width: 16px;
            }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-logo">
                <div class="sidebar-logo-icon"><i class="fas fa-store"></i></div>
                Consumer's Voice
            </div>
            <div class="sidebar-role">● Business Portal</div>
        </div>
        <nav class="sidebar-nav">
            <a class="nav-item active" href="#">
                <i class="fas fa-home"></i> Dashboard
            </a>
            <a class="nav-item" href="#">
                <i class="fas fa-inbox"></i> Complaints Against Us
            </a>
            <a class="nav-item" href="#">
                <i class="fas fa-reply"></i> My Responses
            </a>
            <a class="nav-item" href="#">
                <i class="fas fa-star"></i> Our Rating
            </a>
            <a class="nav-item" href="#">
                <i class="fas fa-building"></i> Business Profile
            </a>
            <a class="nav-item" href="#">
                <i class="fas fa-file-alt"></i> Compliance Record
            </a>
        </nav>
        <div class="sidebar-footer">
            <a href="/Home/Logout" class="logout-btn">
                <i class="fas fa-sign-out-alt"></i> Logout
            </a>
        </div>
    </div>

    <!-- MAIN -->
    <div class="main">
        <div class="topbar">
            <div>
                <h1>Business Portal 🏪</h1>
                <p>Welcome @ViewBag.UserName — Manage complaints and your reputation</p>
            </div>
            <div class="user-badge">
                <div class="user-avatar">
                    @(ViewBag.UserName?.ToString().Substring(0, 1))
                </div>
                <div class="user-info">
                    <div class="name">@ViewBag.UserName</div>
                    <div class="role">Business Owner</div>
                </div>
            </div>
        </div>

        <!-- STATS -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon purple">📋</div>
                <div>
                    <div class="stat-number">5</div>
                    <div class="stat-label">Total Complaints</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon red">🆕</div>
                <div>
                    <div class="stat-number">2</div>
                    <div class="stat-label">New — Need Response</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green">✅</div>
                <div>
                    <div class="stat-number">3</div>
                    <div class="stat-label">Resolved</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon amber">⭐</div>
                <div>
                    <div class="stat-number">4.2</div>
                    <div class="stat-label">Compliance Rating</div>
                </div>
            </div>
        </div>

        <div class="card-grid">
            <div>
                <!-- COMPLAINTS -->
                <div class="card">
                    <h3>📋 Complaints Filed Against Your Business</h3>

                    <div class="complaint-item">
                        <div class="complaint-top">
                            <div>
                                <div class="complaint-title">
                                    Defective Product Sold Without Warranty
                                </div>
                                <div class="complaint-meta">
                                    Filed by: Consumer #1042 · Mar 14, 2026
                                </div>
                            </div>
                            <span class="badge-status badge-new">New</span>
                        </div>
                        <p style="font-size:12px;color:#64748b;margin-top:6px;">
                            Consumer reports purchasing a blender that stopped
                            working after 2 days. Refund was denied by staff.
                        </p>
                        <a href="#" class="respond-btn">
                            <i class="fas fa-reply"></i> Submit Response
                        </a>
                    </div>

                    <div class="complaint-item">
                        <div class="complaint-top">
                            <div>
                                <div class="complaint-title">
                                    Overcharged on Listed Price
                                </div>
                                <div class="complaint-meta">
                                    Filed by: Consumer #0987 · Mar 16, 2026
                                </div>
                            </div>
                            <span class="badge-status badge-new">New</span>
                        </div>
                        <p style="font-size:12px;color:#64748b;margin-top:6px;">
                            Consumer was charged 15,000 RWF above the
                            displayed shelf price for a television set.
                        </p>
                        <a href="#" class="respond-btn">
                            <i class="fas fa-reply"></i> Submit Response
                        </a>
                    </div>

                    <div class="complaint-item">
                        <div class="complaint-top">
                            <div>
                                <div class="complaint-title">
                                    Poor Customer Service Complaint
                                </div>
                                <div class="complaint-meta">
                                    Filed by: Consumer #0854 · Mar 10, 2026
                                </div>
                            </div>
                            <span class="badge-status badge-resolved">Resolved</span>
                        </div>
                        <p style="font-size:12px;color:#64748b;margin-top:6px;">
                            Consumer reported rude treatment by staff.
                            Resolved after apology and staff retraining.
                        </p>
                    </div>
                </div>
            </div>

            <!-- RIGHT COLUMN -->
            <div>
                <!-- RATING -->
                <div class="card">
                    <h3>⭐ Your Compliance Rating</h3>
                    <div class="rating-box">
                        <div class="rating-score">4.2</div>
                        <div class="stars">★★★★☆</div>
                        <div class="rating-label">Based on 5 resolved complaints</div>
                    </div>
                    <p style="font-size:12px;color:#64748b;line-height:1.6;">
                        Your rating improves when you respond quickly
                        and resolve complaints cooperatively with ADECOR Rwanda.
                    </p>
                </div>

                <!-- QUICK ACTIONS -->
                <div class="card">
                    <h3>⚡ Quick Actions</h3>
                    <a href="#" class="action-btn">
                        <i class="fas fa-inbox"></i> View All Complaints
                    </a>
                    <a href="#" class="action-btn">
                        <i class="fas fa-reply"></i> Submit a Response
                    </a>
                    <a href="#" class="action-btn">
                        <i class="fas fa-building"></i> Update Business Profile
                    </a>
                    <a href="#" class="action-btn">
                        <i class="fas fa-file-alt"></i> View Compliance Record
                    </a>
                </div>
            </div>
        </div>
    </div>

</body>
</html>
