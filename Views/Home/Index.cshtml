@{
    ViewData["Title"] = "Welcome";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Consumer's Voice System – ADECOR Rwanda</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            color: #1a1a2e;
        }

        /* NAVBAR */
        .navbar {
            background: #fff;
            padding: 16px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 20px;
            font-weight: 700;
            color: #1a1a2e;
            text-decoration: none;
        }

            .navbar-brand span {
                color: #2563eb;
            }

        .navbar-logo {
            width: 40px;
            height: 40px;
            background: #2563eb;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 18px;
        }

        .nav-buttons {
            display: flex;
            gap: 12px;
        }

        .btn-login {
            padding: 9px 24px;
            border: 2px solid #2563eb;
            color: #2563eb;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.2s;
        }

            .btn-login:hover {
                background: #2563eb;
                color: #fff;
            }

        .btn-signup {
            padding: 9px 24px;
            background: #2563eb;
            color: #fff;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.2s;
        }

            .btn-signup:hover {
                background: #1d4ed8;
            }

        /* HERO */
        .hero {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            color: white;
            padding: 100px 40px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

            .hero::before {
                content: '';
                position: absolute;
                top: -50%;
                left: -50%;
                width: 200%;
                height: 200%;
                background: radial-gradient(circle, rgba(37,99,235,0.15) 0%, transparent 60%);
            }

        .hero-badge {
            display: inline-block;
            background: rgba(37,99,235,0.2);
            border: 1px solid rgba(37,99,235,0.4);
            color: #93c5fd;
            padding: 6px 18px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 24px;
            letter-spacing: 0.06em;
        }

        .hero h1 {
            font-size: 52px;
            font-weight: 800;
            line-height: 1.15;
            margin-bottom: 20px;
        }

            .hero h1 span {
                color: #60a5fa;
            }

        .hero p {
            font-size: 18px;
            color: #94a3b8;
            max-width: 600px;
            margin: 0 auto 40px;
            line-height: 1.7;
        }

        .hero-buttons {
            display: flex;
            gap: 16px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-hero-primary {
            padding: 14px 36px;
            background: #2563eb;
            color: white;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 700;
            font-size: 16px;
            transition: all 0.2s;
        }

            .btn-hero-primary:hover {
                background: #1d4ed8;
                color: white;
                transform: translateY(-2px);
            }

        .btn-hero-secondary {
            padding: 14px 36px;
            background: transparent;
            color: white;
            border: 2px solid rgba(255,255,255,0.3);
            border-radius: 10px;
            text-decoration: none;
            font-weight: 700;
            font-size: 16px;
            transition: all 0.2s;
        }

            .btn-hero-secondary:hover {
                border-color: white;
                color: white;
            }

        /* STATS */
        .stats {
            background: #f8fafc;
            padding: 50px 40px;
            display: flex;
            justify-content: center;
            gap: 60px;
            flex-wrap: wrap;
        }

        .stat-item {
            text-align: center;
        }

        .stat-number {
            font-size: 36px;
            font-weight: 800;
            color: #2563eb;
        }

        .stat-label {
            font-size: 13px;
            color: #64748b;
            margin-top: 4px;
            font-weight: 500;
        }

        /* HOW IT WORKS */
        .section {
            padding: 80px 40px;
        }

        .section-title {
            text-align: center;
            font-size: 32px;
            font-weight: 800;
            margin-bottom: 12px;
        }

        .section-sub {
            text-align: center;
            color: #64748b;
            font-size: 16px;
            margin-bottom: 56px;
        }

        /* ROLES */
        .roles-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 24px;
            max-width: 1100px;
            margin: 0 auto;
        }

        .role-card {
            border-radius: 16px;
            padding: 36px 28px;
            text-align: center;
            transition: transform 0.2s;
            cursor: pointer;
            text-decoration: none;
            display: block;
        }

            .role-card:hover {
                transform: translateY(-6px);
            }

            .role-card.consumer {
                background: #eff6ff;
                border: 2px solid #bfdbfe;
            }

            .role-card.advocate {
                background: #f0fdf4;
                border: 2px solid #bbf7d0;
            }

            .role-card.admin {
                background: #fffbeb;
                border: 2px solid #fde68a;
            }

            .role-card.business {
                background: #fdf4ff;
                border: 2px solid #e9d5ff;
            }

        .role-icon {
            width: 64px;
            height: 64px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
            margin: 0 auto 20px;
        }

        .consumer .role-icon {
            background: #2563eb;
            color: white;
        }

        .advocate .role-icon {
            background: #16a34a;
            color: white;
        }

        .admin .role-icon {
            background: #d97706;
            color: white;
        }

        .business .role-icon {
            background: #9333ea;
            color: white;
        }

        .role-card h3 {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 10px;
            color: #1a1a2e;
        }

        .role-card p {
            font-size: 13px;
            color: #64748b;
            line-height: 1.6;
        }

        /* FEATURES */
        .features-bg {
            background: #f8fafc;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 24px;
            max-width: 1100px;
            margin: 0 auto;
        }

        .feature-card {
            background: white;
            border-radius: 12px;
            padding: 28px;
            border: 1px solid #e2e8f0;
        }

        .feature-icon {
            font-size: 28px;
            margin-bottom: 14px;
        }

        .feature-card h4 {
            font-size: 16px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .feature-card p {
            font-size: 13px;
            color: #64748b;
            line-height: 1.6;
        }

        /* CTA */
        .cta {
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            color: white;
            padding: 80px 40px;
            text-align: center;
        }

            .cta h2 {
                font-size: 36px;
                font-weight: 800;
                margin-bottom: 16px;
            }

            .cta p {
                font-size: 16px;
                color: #bfdbfe;
                margin-bottom: 36px;
            }

        .btn-cta {
            padding: 14px 40px;
            background: white;
            color: #2563eb;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 700;
            font-size: 16px;
            transition: all 0.2s;
            display: inline-block;
        }

            .btn-cta:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(0,0,0,0.2);
            }

        /* FOOTER */
        .footer {
            background: #1a1a2e;
            color: #94a3b8;
            text-align: center;
            padding: 30px 40px;
            font-size: 13px;
        }

            .footer span {
                color: #60a5fa;
                font-weight: 600;
            }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar">
        <a class="navbar-brand" href="/">
            <div class="navbar-logo"><i class="fas fa-shield-alt"></i></div>
            Consumer's <span>Voice</span>
        </a>
        <div class="nav-buttons">
            <a href="/Home/Login" class="btn-login">Log In</a>
            <a href="/Home/Register" class="btn-signup">Sign Up</a>
        </div>
    </nav>

    <!-- HERO -->
    <section class="hero">
        <div class="hero-badge">🇷🇼 ADECOR Rwanda · Consumer Protection Platform</div>
        <h1>Your Rights.<br />Your <span>Voice</span>. Protected.</h1>
        <p>A digital platform empowering Rwandan consumers to report violations, track complaints, and access justice — efficiently and transparently.</p>
        <div class="hero-buttons">
            <a href="/Home/Register" class="btn-hero-primary">Submit a Complaint</a>
            <a href="/Home/Login" class="btn-hero-secondary">Learn More</a>
        </div>
    </section>

    <!-- STATS -->
    <div class="stats">
        <div class="stat-item">
            <div class="stat-number">2,400+</div>
            <div class="stat-label">Complaints Resolved</div>
        </div>
        <div class="stat-item">
            <div class="stat-number">98%</div>
            <div class="stat-label">Consumer Satisfaction</div>
        </div>
        <div class="stat-item">
            <div class="stat-number">30</div>
            <div class="stat-label">Districts Covered</div>
        </div>
        <div class="stat-item">
            <div class="stat-number">48hrs</div>
            <div class="stat-label">Average Response Time</div>
        </div>
    </div>

    <!-- WHO IS IT FOR -->
    <section class="section">
        <div class="section-title">Who Is This Platform For?</div>
        <div class="section-sub">Every user has a dedicated space built for their specific role</div>
        <div class="roles-grid">
            <a href="/Home/Register" class="role-card consumer">
                <div class="role-icon"><i class="fas fa-user"></i></div>
                <h3>Consumer</h3>
                <p>Submit complaints, upload evidence, track your case status and receive real-time updates on your rights.</p>
            </a>
            <a href="/Home/Register" class="role-card advocate">
                <div class="role-icon"><i class="fas fa-briefcase"></i></div>
                <h3>Advocate</h3>
                <p>Manage assigned cases, investigate complaints, communicate with businesses and resolve disputes efficiently.</p>
            </a>
            <a href="/Home/Register" class="role-card admin">
                <div class="role-icon"><i class="fas fa-cog"></i></div>
                <h3>Administrator</h3>
                <p>Oversee all operations, generate reports, monitor SLA compliance and manage the entire platform.</p>
            </a>
            <a href="/Home/Register" class="role-card business">
                <div class="role-icon"><i class="fas fa-store"></i></div>
                <h3>Business Owner</h3>
                <p>View complaints filed against your business, submit responses and maintain your accountability profile.</p>
            </a>
        </div>
    </section>

    <!-- FEATURES -->
    <section class="section features-bg">
        <div class="section-title">Key Features</div>
        <div class="section-sub">Everything needed for effective consumer rights protection</div>
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">📋</div>
                <h4>Structured Complaint Submission</h4>
                <p>Step-by-step guided forms with evidence upload, category selection, and severity rating.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🔔</div>
                <h4>Real-Time Notifications</h4>
                <p>Consumers receive instant SMS and email updates on their complaint status at every stage.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">📊</div>
                <h4>Analytics Dashboard</h4>
                <p>Geographic heatmaps and trend analysis help identify systemic consumer rights violations.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🔒</div>
                <h4>Secure and Private</h4>
                <p>End-to-end encryption and GDPR-compliant data handling protects all consumer information.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">⏱️</div>
                <h4>SLA Tracking</h4>
                <p>Automated deadline monitoring ensures no complaint goes unattended past its resolution target.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🌍</div>
                <h4>Nationwide Coverage</h4>
                <p>Accessible to consumers across all 30 districts of Rwanda including offline capability.</p>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="cta">
        <h2>Ready To Protect Your Rights?</h2>
        <p>Join thousands of Rwandan consumers already using the platform</p>
        <a href="/Home/Register" class="btn-cta">Get Started Free</a>
    </section>

    <!-- FOOTER -->
    <footer class="footer">
        <p>© 2026 <span>Consumer's Voice System</span> · ADECOR Rwanda · All rights reserved</p>
    </footer>

</body>
</html>
