@model ConsumersVoiceSystemPrototype.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login – Consumer's Voice System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }

        .login-wrapper {
            display: flex;
            width: 100%;
            max-width: 900px;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 25px 60px rgba(0,0,0,0.4);
        }

        /* LEFT PANEL */
        .left-panel {
            background: linear-gradient(160deg, #2563eb, #1d4ed8);
            color: white;
            padding: 60px 40px;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

            .left-panel .logo {
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 48px;
            }

            .left-panel .logo-icon {
                width: 44px;
                height: 44px;
                background: rgba(255,255,255,0.2);
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 20px;
            }

            .left-panel .logo-text {
                font-size: 18px;
                font-weight: 700;
            }

            .left-panel h2 {
                font-size: 28px;
                font-weight: 800;
                margin-bottom: 16px;
                line-height: 1.3;
            }

            .left-panel p {
                font-size: 14px;
                color: #bfdbfe;
                line-height: 1.7;
                margin-bottom: 36px;
            }

        .test-accounts {
            margin-top: 8px;
        }

            .test-accounts h4 {
                font-size: 12px;
                font-weight: 700;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: #93c5fd;
                margin-bottom: 12px;
            }

        .account-item {
            background: rgba(255,255,255,0.1);
            border-radius: 8px;
            padding: 10px 14px;
            margin-bottom: 8px;
            font-size: 12px;
        }

            .account-item .role-tag {
                font-weight: 700;
                color: #fbbf24;
                display: block;
                margin-bottom: 2px;
            }

            .account-item .creds {
                color: #e0f2fe;
            }

        /* RIGHT PANEL */
        .right-panel {
            background: white;
            padding: 60px 44px;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

            .right-panel h3 {
                font-size: 26px;
                font-weight: 800;
                color: #1a1a2e;
                margin-bottom: 6px;
            }

            .right-panel .subtitle {
                font-size: 14px;
                color: #64748b;
                margin-bottom: 36px;
            }

        .form-label {
            font-size: 13px;
            font-weight: 600;
            color: #374151;
            margin-bottom: 6px;
        }

        .input-group-icon {
            position: relative;
            margin-bottom: 20px;
        }

            .input-group-icon i {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #94a3b8;
                font-size: 14px;
            }

            .input-group-icon input {
                width: 100%;
                padding: 12px 14px 12px 40px;
                border: 2px solid #e2e8f0;
                border-radius: 10px;
                font-size: 14px;
                transition: border-color 0.2s;
                outline: none;
            }

                .input-group-icon input:focus {
                    border-color: #2563eb;
                }

        .btn-submit {
            width: 100%;
            padding: 13px;
            background: #2563eb;
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
            margin-top: 8px;
        }

            .btn-submit:hover {
                background: #1d4ed8;
                transform: translateY(-1px);
            }

        .error-box {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #dc2626;
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 20px;
        }

        .register-link {
            text-align: center;
            margin-top: 24px;
            font-size: 13px;
            color: #64748b;
        }

            .register-link a {
                color: #2563eb;
                font-weight: 700;
                text-decoration: none;
            }

        .back-link {
            text-align: center;
            margin-top: 16px;
        }

            .back-link a {
                font-size: 13px;
                color: #94a3b8;
                text-decoration: none;
            }

                .back-link a:hover {
                    color: #2563eb;
                }

        @@media (max-width: 640px) {
            .left-panel {
                display: none;
            }

            .login-wrapper {
                max-width: 440px;
            }
        }
    </style>
</head>
<body>

    <div class="login-wrapper">

        <!-- LEFT PANEL -->
        <div class="left-panel">
            <div class="logo">
                <div class="logo-icon"><i class="fas fa-shield-alt"></i></div>
                <div class="logo-text">Consumer's Voice</div>
            </div>
            <h2>Welcome Back to ADECOR Rwanda</h2>
            <p>Log in to access your personalized dashboard and manage your consumer rights activities.</p>

            <div class="test-accounts">
                <h4>Test Accounts</h4>
                <div class="account-item">
                    <span class="role-tag">Consumer</span>
                    <span class="creds">consumer@test.com · password123</span>
                </div>
                <div class="account-item">
                    <span class="role-tag">Advocate</span>
                    <span class="creds">advocate@test.com · password123</span>
                </div>
                <div class="account-item">
                    <span class="role-tag">Admin</span>
                    <span class="creds">admin@test.com · password123</span>
                </div>
                <div class="account-item">
                    <span class="role-tag">Business</span>
                    <span class="creds">business@test.com · password123</span>
                </div>
            </div>
        </div>

        <!-- RIGHT PANEL -->
        <div class="right-panel">
            <h3>Sign In</h3>
            <p class="subtitle">Enter your credentials to access your dashboard</p>

            @if (ViewBag.Error != null)
            {
                <div class="error-box">
                    <i class="fas fa-exclamation-circle"></i> @ViewBag.Error
                </div>
            }

            <form method="post" action="/Home/Login">
                @Html.AntiForgeryToken()

                <label class="form-label">Email Address</label>
                <div class="input-group-icon">
                    <i class="fas fa-envelope"></i>
                    <input type="email" name="Email" placeholder="Enter your email" required />
                </div>

                <label class="form-label">Password</label>
                <div class="input-group-icon">
                    <i class="fas fa-lock"></i>
                    <input type="password" name="Password" placeholder="Enter your password" required />
                </div>

                <button type="submit" class="btn-submit">
                    <i class="fas fa-sign-in-alt"></i> Sign In
                </button>
            </form>

            <div class="register-link">
                Don't have an account? <a href="/Home/Register">Create one here</a>
            </div>
            <div class="back-link">
                <a href="/"><i class="fas fa-arrow-left"></i> Back to Home</a>
            </div>
        </div>

    </div>

</body>
</html>
